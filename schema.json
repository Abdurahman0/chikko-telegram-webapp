g\n        line_total:\n          type: string\n      required:\n      - line_total\n      - product_id\n      - product_name\n      - quantity\n      - unit_price\n    TelegramWebAppOrders:\n      type: object\n      properties:\n        orders:\n          type: array\n          items:\n            $ref: \u0027#/components/schemas/TelegramWebAppOrderHistory\u0027\n      required:\n      - orders\n    TelegramWebAppPayment:\n      type: object\n      properties:\n        id:\n          type: string\n          format: uuid\n        amount:\n          type: string\n        status:\n          type: string\n        method:\n          type: string\n      required:\n      - amount\n      - id\n      - method\n      - status\n    TelegramWebAppProduct:\n      type: object\n      properties:\n        id:\n          type: string\n          format: uuid\n          readOnly: true\n        name:\n          type: string\n          maxLength: 255\n        sku:\n          type: string\n          maxLength: 120\n        category:\n          allOf:\n          - $ref: \u0027#/components/schemas/ProductCategory\u0027\n          readOnly: true\n        brand:\n          allOf:\n          - $ref: \u0027#/components/schemas/ProductBrand\u0027\n          readOnly: true\n        description:\n          type: string\n        price:\n          type: string\n          format: decimal\n          pattern: ^-?\\d{0,10}(?:\\.\\d{0,2})?$\n        currency:\n          type: string\n          maxLength: 8\n        stock_quantity:\n          type: integer\n          maximum: 2147483647\n          minimum: 0\n        minimal_stock:\n          type: integer\n          maximum: 2147483647\n          minimum: 0\n        has_stock:\n          type: string\n          readOnly: true\n        is_favorite:\n          type: boolean\n          readOnly: true\n          default: false\n        images:\n          type: array\n          items:\n            $ref: \u0027#/components/schemas/ProductImage\u0027\n          readOnly: true\n      required:\n      - brand\n      - category\n      - has_stock\n      - id\n      - images\n      - is_favorite\n      - name\n      - sku\n    TelegramWebAppProfile:\n      type: object\n      properties:\n        user:\n          $ref: \u0027#/components/schemas/TelegramWebAppUser\u0027\n        customer:\n          $ref: \u0027#/components/schemas/TelegramWebAppCustomer\u0027\n        active_order:\n          allOf:\n          - $ref: \u0027#/components/schemas/TelegramWebAppOrder\u0027\n          nullable: true\n        order_history:\n          type: array\n          items:\n            $ref: \u0027#/components/schemas/TelegramWebAppOrderHistory\u0027\n        favorites:\n          type: array\n          items:\n            $ref: \u0027#/components/schemas/TelegramWebAppProduct\u0027\n        pending_reviews:\n          type: array\n          items:\n            $ref: \u0027#/components/schemas/TelegramWebAppOrder\u0027\n      required:\n      - active_order\n      - customer\n      - favorites\n      - order_history\n      - pending_reviews\n      - user\n    TelegramWebAppReview:\n      type: object\n      properties:\n        id:\n          type: string\n          format: uuid\n        order_id:\n          type: string\n          format: uuid\n        comment:\n          type: string\n        requested_at:\n          type: string\n          format: date-time\n          nullable: true\n        submitted_at:\n          type: string\n          format: date-time\n          nullable: true\n        source:\n          type: string\n        order:\n          $ref: \u0027#/components/schemas/TelegramWebAppOrder\u0027\n      required:\n      - comment\n      - id\n      - order\n      - order_id\n      - requested_at\n      - source\n      - submitted_at\n    TelegramWebAppReviewSubmitRequest:\n      type: object\n      properties:\n        order_id:\n          type: string\n          format: uuid\n        comment:\n          type: string\n  