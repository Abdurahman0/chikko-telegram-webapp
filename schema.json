pe: string\n          minLength: 1\n          maxLength: 255\n        phone:\n          type: string\n          maxLength: 32\n        role:\n          $ref: \u0027#/components/schemas/RoleEnum\u0027\n        is_active:\n          type: boolean\n        password:\n          type: string\n          writeOnly: true\n          minLength: 8\n        custom_permission_ids:\n          type: array\n          items:\n            type: string\n            format: uuid\n            writeOnly: true\n          writeOnly: true\n      required:\n      - email\n      - full_name\n  securitySchemes:\n    jwtAuth:\n      type: http\n      scheme: bearer\n      bearerFormat: JWT\n"
